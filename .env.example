# ReplyWise AI configuration. Copy to .env and fill in as needed.
# Everything is optional: with no keys set, the system runs in mock mode.

# --- LLM generation (pick one provider; leave all blank for mock mode) ---
# Optional hard override of provider selection: groq | anthropic | openai | mock
REPLYWISE_PROVIDER=

# Groq (OpenAI-compatible, fast + free tier). Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model id. Leave blank to use the provider's sensible default:
#   groq -> llama-3.3-70b-versatile, anthropic -> claude-sonnet-5, openai -> gpt-4o-mini
REPLYWISE_MODEL=
REPLYWISE_MAX_TOKENS=600
REPLYWISE_TEMPERATURE=0.3

# --- Retrieval ---
REPLYWISE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
REPLYWISE_TOP_K=4

# --- Evaluation ---
REPLYWISE_PASS_THRESHOLD=0.70
REPLYWISE_MNI_PENALTY=0.5
# Enable the optional LLM-as-judge metric (requires an API key)
REPLYWISE_USE_JUDGE=false
